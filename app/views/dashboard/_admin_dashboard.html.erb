<div class="flex min-h-screen">

  <!-- Main content -->
  <div class="flex-1 p-10 space-y-20 flex flex-col items-center">
    <!-- Welcome Message -->
    <p class="text-lg text-gray-700 font-semibold text-center text-2xl">Welcome, Admin</p>
  
    <!-- Statistic Tiles -->
    <div class="flex gap-10">
      <div class="bg-white p-6 rounded-lg shadow w-64 text-center">
        <p class="text-gray-500 mb-5">Buy Transactions</p>
        <p class="text-2xl font-bold"><%= Transaction.where(transaction_type: 'buy').count %></p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow w-64 text-center">
        <p class="text-gray-500 mb-5">Sell Transactions</p>
        <p class="text-2xl font-bold"><%= Transaction.where(transaction_type: 'sell').count %></p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow w-64 text-center">
        <p class="text-gray-500 mb-5">Funds</p>
        <p class="text-2xl font-bold"><%= number_to_currency(current_user.funds) %></p>
      </div>
    </div>
  </div>
  


    </div>
  </div>
</div>
