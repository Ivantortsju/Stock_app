<div x-data="{ open: true }" 
     class="bg-[#2a3042] text-black h-screen transition-all duration-300"
     :class="{ 'w-64': open, 'w-20': !open }">

  <!-- Top bar -->
  <div class="flex items-center justify-between px-4 h-16 border-b border-gray-700">
    <span class="text-lg font-bold" x-show="open" x-transition>📊 Admin</span>
    <button @click="open = !open" class="text-white">
      ☰
    </button>
  </div>

  <!-- Navigation -->
  <nav class="px-3 py-4 space-y-2">
    <li class="flex items-center space-x-2 px-3 py-2 rounded  hover:bg-[#1f2533]">
      <span>🏠</span>
      <span x-show="open" x-transition><%= link_to 'Dashboard', dashboard_index_path %></span>
    </li>

    <div class="flex items-center px-3 py-2 rounded hover:bg-[#1f2533]">
      <span>➕</span>
      <span x-show="open" x-transition class="pl-2">
        <%= link_to 'Create New Trader', new_admin_user_path %>
      </span>
    </div>

    <div class="flex items-center px-3 py-2 rounded hover:bg-[#1f2533]">
      <span>👥</span>
      <span x-show="open" x-transition class="pl-2">
        <%= link_to 'Manage Traders', admin_users_path %>
      </span>
    </div>

    <div class="flex items-center px-3 py-2 rounded hover:bg-[#1f2533]">
      <span>⏳</span>
      <span x-show="open" x-transition class="pl-2">
        <%= link_to 'Pending Traders', admin_pending_traders_path %>
      </span>
    </div>

    <div class="flex items-center px-3 py-2 rounded hover:bg-[#1f2533]">
      <span>💰</span>
      <span x-show="open" x-transition class="pl-2">
        <%= link_to 'All Transactions', admin_transactions_path %>
      </span>
    </div>
  </nav>
</div>
