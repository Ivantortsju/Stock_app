<% if object.errors.any? %>
  <div id="error_explanation" class="mb-4 p-2 bg-red-100 border border-red-400 rounded">
    <h2 class="font-bold text-red-700"><%= pluralize(object.errors.count, "error") %> prohibited this record from being saved:</h2>
    <ul class="list-disc ml-6">
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
