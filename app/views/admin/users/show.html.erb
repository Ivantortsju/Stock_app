<p>
  <strong>Name:</strong>
  <%= @user.name %>
</p>
<p>
  <strong>Surname:</strong>
  <%= @user.surname %>
</p>
<p>
  <strong>Email:</strong>
  <%= @user.email %>
</p>

<%= link_to 'Edit', edit_admin_user_path(@user), class: 'btn btn-primary' %>
<br>
<br>

<h3>Transaction History</h3>
<% if @user.transactions.any? %>
  <table class="min-w-full border rounded-lg overflow-hidden mt-4">
    <thead class="bg-gray-100">
      <tr>
        <th class="px-4 py-2">Date</th>
        <th class="px-4 py-2">Type</th>
        <th class="px-4 py-2">Ticker</th>
        <th class="px-4 py-2">Quantity</th>
        <th class="px-4 py-2">Price/Share</th>
      </tr>
    </thead>
    <tbody>
      <% @user.transactions.order(created_at: :desc).each do |tx| %>
        <tr>
          <td class="py-2 px-4"><%= tx.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td class="py-2 px-4"><%= tx.transaction_type.capitalize %></td>
          <td class="py-2 px-4"><%= tx.ticker %></td>
          <td class="py-2 px-4"><%= tx.quantity %></td>
          <td class="py-2 px-4"><%= number_to_currency(tx.price_per_share) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>This trader has no transactions yet.</p>
<% end %>
<br>
<%= link_to 'Back', admin_users_path, class: 'btn btn-secondary' %>