<h1 class="text-2xl font-bold mb-4">Traders</h1>
<form method="get" action="" class="mb-4 flex items-center gap-2">
  <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search traders..." class="px-3 py-2 border rounded-md w-64" />
  <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-md">Search</button>
</form>
<table class="min-w-full border rounded-lg overflow-hidden">
  <thead class="bg-gray-100">
    <tr>
      <% columns = { 'name' => 'Name', 'surname' => 'Surname', 'email' => 'Email' } %>
      <% columns.each do |col, label| %>
        <% dir = (params[:sort] == col && params[:direction] == 'asc') ? 'desc' : 'asc' %>
        <th class="px-4 py-2 cursor-pointer <%= 'text-blue-700 underline' if params[:sort] == col %>">
          <%= link_to label, admin_users_path(q: params[:q], sort: col, direction: dir), class: 'hover:underline' %>
          <% if params[:sort] == col %>
            <%= params[:direction] == 'asc' ? '▲' : '▼' %>
          <% end %>
        </th>
      <% end %>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr class="hover:bg-blue-50 transition cursor-pointer" onclick="window.location='<%= admin_user_path(user) %>'">
  <td class="py-2 px-4"><%= user.name %></td>
  <td class="py-2 px-4"><%= user.surname %></td>
  <td class="py-2 px-4"><%= user.email %></td>
  <td class="py-2 px-4">
    <%= button_to 'Delete', admin_user_path(user), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'text-red-600 hover:underline bg-transparent border-none p-0' %>
    <%= button_to 'Reject', reject_admin_user_path(user), method: :patch, data: { turbo_confirm: 'Move this trader back to pending approval?' }, class: 'text-yellow-600 hover:underline bg-transparent border-none p-0 ml-2' %>
  </td>
</tr>
    <% end %>
  </tbody>
</table>

<div style="position: fixed; bottom: 20px; right: 20px;">
  <%= link_to 'Home', root_path, class: 'btn btn-primary' %>
</div>
