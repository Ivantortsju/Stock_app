<h1>Search Stocks</h1>

<%= form_tag search_stock_path, method: :get do %>
  <div class="form-group">
    <%= label_tag :stock, 'Ticker Symbol' %>
    <%= text_field_tag :stock, params[:stock], class: 'form-control', placeholder: 'Enter ticker symbol' %>
  </div>
  <%= submit_tag 'Search', class: 'btn btn-primary' %>
<% end %>

<% if @stock %>
  <div class="mt-4">
    <h2><%= @stock.name %> (<%= @stock.ticker %>)</h2>
    <p><strong>Price:</strong> <%= @stock.last_price %></p>

  </div>
  <%= form_with url: buy_stock_path, local: true do |form| %>
    <%= form.hidden_field :ticker, value: @stock.ticker %>
    <div class="form-group">
      <%= form.label :shares, 'Shares' %>
      <%= form.number_field :shares, class: 'form-control', min: 1, required: true %>
    </div>
    <%= form.submit 'Buy', class: 'btn btn-success' %>
  <% end %>
  
<% elsif @available_stocks %>
  <div class="mt-4">
    <h2>Available Stocks</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Name (Symbol)</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @available_stocks.each do |stock| %>
          <tr>
            <td><%= stock.name %> (<%= stock.ticker %>)</td>
            <td><%= stock.last_price %></td>
            <td>
              <%= form_with url: buy_stock_path, local: true, class: 'form-inline' do |form| %>
                <%= form.hidden_field :ticker, value: stock.ticker %>
                <div class="form-group mx-sm-3 mb-2">
                  <%= form.number_field :shares, class: 'form-control', min: 1, required: true, placeholder: 'Quantity' %>
                </div>
                <%= form.submit 'Buy', class: 'btn btn-success mb-2', data: { turbo_confirm: "Are you sure you want to buy these shares?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
<% end %>
